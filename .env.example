# === 前置条件 ===
# 1. 安装 dws CLI 工具（钉钉 workspace 命令行）
#    前往 https://github.com/anthropic/dws 下载安装
# 2. 安装后执行 dws login 登录你的钉钉账号
# 3. 确保 dws 在系统 PATH 中（终端输入 dws --version 能正常输出）

# === 钉钉开放平台 ===
# 前往 https://open-dev.dingtalk.com/ 创建企业内部机器人，获取以下两串密钥
DINGTALK_CLIENT_ID=请填写你的ClientID
DINGTALK_CLIENT_SECRET=请填写你的ClientSecret

# === AI API ===
# 前往对应平台获取 API Key 和 Base URL
ANTHROPIC_API_KEY=请填写你的APIKey
ANTHROPIC_BASE_URL=请填写你的BaseURL

# 模型名称：claude-sonnet-4-5 / claude-sonnet-4-6 / anthropic/claude-|deepseek-v4-pro 等
CLAUDE_MODEL=claude-sonnet-4-5
